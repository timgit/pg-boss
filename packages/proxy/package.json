{
  "name": "@pg-boss/proxy",
  "version": "1.5.0",
  "description": "HTTP proxy for pg-boss",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pg-boss-proxy": "bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "cross-env DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/pgboss tsx src/server.ts",
    "gen:version": "tsx scripts/gen-version.ts",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run gen:version && tsc -p tsconfig.build.json",
    "test": "vitest run -c vitest.config.ts",
    "start": "node ./dist/server.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@logtape/hono": "^2.2.2",
    "@logtape/logtape": "^2.2.2",
    "hono": "^4.12.27",
    "pg-boss": "^12.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timgit/pg-boss.git"
  },
  "author": "timgit",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/timgit/pg-boss/issues"
  },
  "homepage": "https://timgit.github.io/pg-boss",
  "keywords": [
    "pg-boss",
    "job-queue",
    "proxy",
    "http",
    "hono"
  ]
}
